#!/bin/bash
# Claude Code Development Stop Script
# Stops all development services

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_info() {
    echo -e "[INFO] $1"
}

echo "========================================"
echo " Stopping Development Services"
echo "========================================"
echo ""

FOUND_ANY=0

# Function to stop by PID file
stop_by_pid_file() {
    local SERVICE_NAME=$1
    local PID_FILE=$2

    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p $PID > /dev/null 2>&1; then
            kill $PID 2>/dev/null || true
            sleep 1
            if ! ps -p $PID > /dev/null 2>&1; then
                print_success "$SERVICE_NAME stopped (PID: $PID)"
                FOUND_ANY=1
            else
                kill -9 $PID 2>/dev/null || true
                print_success "$SERVICE_NAME stopped (forced, PID: $PID)"
                FOUND_ANY=1
            fi
        fi
        rm -f "$PID_FILE"
    fi
}

# Function to stop by port (Windows-compatible using netstat + taskkill)
stop_by_port() {
    local SERVICE_NAME=$1
    local PORT=$2

    # Use netstat to find PIDs listening on port (Windows command)
    PIDS=$(netstat -ano | grep ":$PORT.*LISTENING" | awk '{print $NF}' | sort -u)

    if [ ! -z "$PIDS" ]; then
        for PID in $PIDS; do
            if [ "$PID" != "0" ]; then
                taskkill //F //PID $PID > /dev/null 2>&1 || true
                print_success "$SERVICE_NAME stopped (port $PORT, PID: $PID)"
                FOUND_ANY=1
            fi
        done
    fi
}

# Stop services by PID files first (graceful)
echo "[1/3] Stopping frontend server..."
stop_by_pid_file "Frontend" ".logs/frontend.pid"
# Also kill by port to catch any strays
stop_by_port "Frontend" "5173"
if [ $FOUND_ANY -eq 0 ]; then
    print_info "Frontend not running"
fi

FOUND_ANY=0
echo ""
echo "[2/3] Stopping backend server..."
stop_by_pid_file "Backend" ".logs/backend.pid"
stop_by_port "Backend" "8000"
if [ $FOUND_ANY -eq 0 ]; then
    print_info "Backend not running"
fi

FOUND_ANY=0
echo ""
echo "[3/3] Stopping ngrok tunnel..."
stop_by_pid_file "ngrok" ".logs/ngrok.pid"
stop_by_port "ngrok" "4040"
# Also kill any ngrok.exe processes
taskkill //F //IM ngrok.exe > /dev/null 2>&1 || true
if [ $FOUND_ANY -eq 0 ]; then
    print_info "ngrok not running"
fi

echo ""
echo "========================================"
echo " All Services Stopped"
echo "========================================"
echo ""
