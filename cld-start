#!/bin/bash
# Claude Code Development Start Script
# Starts backend, ngrok, and frontend in background for testing

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

print_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

print_info() {
    echo -e "[INFO] $1"
}

echo "========================================"
echo " Starting Development Services"
echo " (Background Mode)"
echo "========================================"
echo ""

# Check if venv exists
if [ ! -d "venv" ]; then
    print_error "Virtual environment not found"
    echo "Please run 'bash scripts/linux/install.sh' first"
    exit 1
fi
print_info "Virtual environment found"

# Check if .env exists
if [ ! -f ".env" ]; then
    print_error ".env file not found"
    echo "Please run 'bash scripts/linux/install.sh' or copy .env.example to .env"
    exit 1
fi
print_info ".env file found"

# Check if frontend dependencies are installed
if [ ! -d "frontend/node_modules" ]; then
    print_error "Frontend dependencies not installed"
    echo "Please run 'bash scripts/linux/install.sh' first"
    exit 1
fi
print_info "Frontend dependencies installed"

echo ""

# Activate virtual environment
source venv/bin/activate

# Create logs directory
mkdir -p .logs

# Start backend
echo "[1/3] Starting backend server..."
nohup venv/Scripts/python.exe -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000 > .logs/backend.log 2>&1 &
BACKEND_PID=$!
echo $BACKEND_PID > .logs/backend.pid
sleep 3

# Verify backend started
if ps -p $BACKEND_PID > /dev/null 2>&1; then
    print_success "Backend started (PID: $BACKEND_PID) - http://localhost:8000"
else
    print_error "Backend failed to start - check .logs/backend.log"
    exit 1
fi

# Start ngrok
echo ""
echo "[2/3] Starting ngrok tunnel..."
if command -v ngrok &> /dev/null; then
    nohup ngrok http 8000 > .logs/ngrok.log 2>&1 &
    NGROK_PID=$!
    echo $NGROK_PID > .logs/ngrok.pid
    sleep 2

    if ps -p $NGROK_PID > /dev/null 2>&1; then
        print_success "ngrok started (PID: $NGROK_PID) - UI: http://localhost:4040"
    else
        print_error "ngrok failed to start - check .logs/ngrok.log"
    fi
else
    print_info "ngrok not installed (optional)"
fi

# Start frontend
echo ""
echo "[3/3] Starting frontend server..."
cd frontend
nohup npm run dev > ../.logs/frontend.log 2>&1 &
FRONTEND_PID=$!
echo $FRONTEND_PID > ../.logs/frontend.pid
cd ..
sleep 2

# Verify frontend started
if ps -p $FRONTEND_PID > /dev/null 2>&1; then
    print_success "Frontend started (PID: $FRONTEND_PID) - http://localhost:5173"
else
    print_error "Frontend failed to start - check .logs/frontend.log"
fi

echo ""
echo "========================================"
echo " All Services Running"
echo "========================================"
echo "  Backend:  http://localhost:8000"
echo "  Frontend: http://localhost:5173"
echo "  API Docs: http://localhost:8000/docs"
echo "  ngrok UI: http://localhost:4040"
echo "========================================"
echo ""
echo "Logs saved to .logs/ directory"
echo "To stop all services, run: ./cld-stop"
echo ""
